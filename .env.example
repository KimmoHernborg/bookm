# SQLite file path
DATABASE_URL=./data/bookm.db
# Root for data files
DATA_DIR=./data

# Better Auth — generate a secret: bunx --bun @better-auth/cli secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Bootstraps the first admin when the users table is empty; the generated
# password is printed once in the server logs.
ADMIN_EMAIL=

# Allow public sign-up (default: false — admin creates users via /admin)
REGISTRATION_OPEN=false

# Required for AI tagging
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Max characters of extracted page text sent to the LLM per bookmark
EXTRACTION_MAX_CHARS=8000
# Max concurrent background jobs
JOB_CONCURRENCY=3
